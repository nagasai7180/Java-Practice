<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Futuristic Bike Showroom</title>

<style>

/* =========================
   CONTROL SETTINGS
========================= */

:root{
--title-size:70px;
--shine:#00f7ff;
--card-width:260px;
--card-height:420px;
--tilt:10deg;
}

/* ========================= */

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:black;
height:100vh;
overflow:hidden;
font-family:Arial, Helvetica, sans-serif;
}

/* =========================
   BACKGROUND SLIDESHOW
========================= */

.slideshow{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
z-index:0;
}

.slide{
position:absolute;
width:100%;
height:100%;
background-size:cover;
background-position:center;
opacity:0;
animation:slideShow 30s infinite;
filter:brightness(0.45);
}

.slide:nth-child(1){
background-image:url("https://i.pinimg.com/originals/85/05/05/8505051384604a66d6af0f6662e7dd44.gif");
animation-delay:0s;
}

.slide:nth-child(2){
background-image:url("https://media3.giphy.com/media/v1.Y2lkPTZjMDliOTUyY3h6MGY5OGI1YzJubTlncjV2dzJ5cDljZzM0OHF3YmNjYmxtZXJycSZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/xTiTnxpQ3ghPiB2Hp6/source.gif");
animation-delay:6s;
}

.slide:nth-child(3){
background-image:url("https://i.pinimg.com/originals/e4/28/15/e428152eecbc597a0617dc7be7c7d418.gif");
animation-delay:12s;
}

.slide:nth-child(4){
background-image:url("https://giffiles.alphacoders.com/150/15053.gif");
animation-delay:18s;
}

.slide:nth-child(5){
background-image:url("https://i.pinimg.com/originals/7d/df/32/7ddf320ed00ca33a7e965493bf2255cf.gif");
animation-delay:24s;
}

@keyframes slideShow{

0%{opacity:0;}
5%{opacity:1;}
20%{opacity:1;}
25%{opacity:0;}
100%{opacity:0;}

}

/* =========================
   HEADING
========================= */

.title{
position:absolute;
top:40px;
left:50%;
transform:translateX(-50%);
font-size:var(--title-size);
letter-spacing:6px;
white-space:nowrap;
color:var(--shine);
text-shadow:
0 0 10px var(--shine),
0 0 30px var(--shine),
0 0 60px var(--shine);
z-index:10;
}

/* =========================
   CARD CONTAINER
========================= */

.cards{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
display:flex;
gap:40px;
z-index:5;
}

/* =========================
   CARD
========================= */

.card{

width:var(--card-width);
height:var(--card-height);

transform:skewX(calc(-1 * var(--tilt)));

border-radius:10px;

background-size:cover;
background-position:center;

overflow:hidden;

box-shadow:
0 0 20px #00ffff40,
0 0 60px #00ffff20;

transition:0.5s;

position:relative;

cursor:pointer;

}

.card:hover{

transform:skewX(calc(-1 * var(--tilt))) scale(1.1);

box-shadow:
0 0 40px #00ffff,
0 0 80px #00ffff;

}

/* overlay */

.card::after{
content:"";
position:absolute;
width:100%;
height:100%;
background:rgba(0,0,0,0.4);
}

/* =========================
   BIKE NAME
========================= */

.bike-name{

position:absolute;
top:30px;
left:50%;
transform:translateX(-50%) skewX(var(--tilt));

color:white;
font-size:22px;

letter-spacing:2px;

text-shadow:0 0 10px #00ffff;

z-index:2;

}

/* =========================
   COMING SOON
========================= */

.tag{

position:absolute;
bottom:40px;
left:50%;

transform:translateX(-50%) skewX(var(--tilt));

font-size:26px;
font-weight:bold;

color:#00ffff;

letter-spacing:4px;

text-shadow:
0 0 10px #00ffff,
0 0 30px #00ffff;

z-index:2;

}

/* =========================
   CARD IMAGES
========================= */

.card1{
background-image:url("https://www.slashgear.com/img/gallery/6-futuristic-motorcycles-that-actually-exist/arc-vector-1733391512.jpg");
}

.card2{
background-image:url("https://mir-s3-cdn-cf.behance.net/project_modules/fs/51974a34438857.56d1cded3a57e.jpg");
}

.card3{
background-image:url("https://i.pinimg.com/originals/84/d2/7b/84d27bf05fb6b6ecd6a24f559a619e39.jpg");
}

.card4{
background-image:url("https://wirecase3d.com/cdn/shop/products/bike1.jpg?v=1532863204&width=1445");
}

</style>
</head>

